100 defint a-z
110 for jis=1 to 2:p1=&HD8+2*(jis-1):p2=p1+1
120 f$="JISKAN"+chr$(jis+&h30)+".BIN":?f$":";
130 open f$ as #1 len=32
140 field #1, 32 as g$
150 for k=0 to 63
160 out p2,k
170 for t=0 to 63
180 out p1,t
190 for i=0 to 31
200 mid$(g$,i+1,1)=chr$(inp(p2))
210 next i
220 put #1,k*64+t+1
230 next t
240 ?".";
250 next k
260 close#1
270 ?
280 next jis
290 end
