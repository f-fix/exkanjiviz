10 DEFINT A-Z:SCREEN 1:WIDTH 32:COLOR 15,1,1:KEY OFF:CLS
20 PRINT"Kanji behavior test
30 PRINT"Japanese BIOS 8x8 Kanji:
40 FOR I=&H41 TO &H5F:PRINTMID$(CHR$(&H1)+CHR$(I),1-2*(I>=&H50 AND I<=&H5C));:NEXT:PRINT
50 PRINT"I/O port Kanji:
60 OUT &HD9,&H2:OUT &HD8,&H3C:OUT &HDB,&H2:OUT &HDA,&H3A
70 FOR Y=0 TO 1:FOR X=2 TO 3:FOR J=0 TO 7:LOCATE 8*X,4+8*Y+J:G=INP(&HDB):M=&H80:FOR I=0 TO 7:PRINTMID$(CHR$(&HA5)+CHR$(&HFF),1+(G\M)MOD 2,1);:M=M\2:NEXT I:NEXT J:NEXT X:NEXT Y
80 FOR Y=0 TO 1:FOR X=0 TO 1:FOR J=0 TO 7:LOCATE 8*X,4+8*Y+J:G=INP(&HD9):M=&H80:FOR I=0 TO 7:PRINTMID$(CHR$(&HA5)+CHR$(&HFF),1+(G\M)MOD 2,1);:M=M\2:NEXT I:NEXT J:NEXT X:NEXT Y
90 LOCATE 0,20:PRINT"Please share screen pic & model
