1000 CLEAR 1024,&HCFFF:DEFINT A-Z:SCREEN 0:COLOR 15,1,1:KEY OFF:CLS:GOSUB 2000
1010 S$="YAMAHA-MSX-JWP-SYSTEM"'Found at 0x4010
1020 PRINT"Get SKW-01/SKW-05 ";S$
1030 E=&HFCC1'EXPTBL
1040 FOR P=0 TO 3'primary slots
1050 N=0:X=0:IF INT(PEEK(E+P)/128)=1 THEN X=&H80:N=3
1060 FOR S=0 TO N
1070 I=X+P+4*S:POKE &HD000,I
1080 I$=CHR$(P+&H30):IF X<>0 THEN I$=I$+"-"+CHR$(S+&H30)
1090 PRINT"Slot ";I$;:PRINT" ($"HEX$(I)") $4000: ";
1100 IF CHR$(USR(&H4000))+CHR$(USR(&H4001))="AB" THEN PRINT"Bootable":ELSE PRINT"--"
1110 T$="":FOR J=&H4010 TO &H4010+LEN(S$)-1:T$=T$+CHR$(USR(J)):NEXT J
1120 IF T$=S$ THENPRINT"    "T$:ELSE GOTO 1970
1130 PRINT"    Kanji Word Processor
1200 O$="MAIN"+I$+".ROM":PRINT"Get "O$;
1210 OPEN O$ AS #1 LEN=128:FIELD #1, 128 AS G$
1220 FOR H=&H0 TO &H7F:PRINT".";:FOR L=&H0 TO &HFF
1230 MID$(G$,1+(L MOD 128),1)=CHR$(USR(H*&H100+L)):IF (L MOD 128)=&H7F THEN PUT #1,1+(H*2)+(L \ 128)
1280 NEXT L:NEXT H
1290 CLOSE #1:PRINT
1300 O$="FONT"+I$+".ROM":PRINT"Get "O$;
1310 OPEN O$ AS #1 LEN=128:FIELD #1, 128 AS G$
1320 FOR G=0 TO 3:PRINT:PRINT"    Group";G;
1330 FOR H=&H0 TO &H7F:PRINT".";:FOR L=&H0 TO &HFF
1340 POKE&HD002,&H7F:POKE &HD001,&HC1+G+G:V=USR1(H):POKE &HD001,&HC0+G+G:V=USR1(L)
1360 MID$(G$,1+(L MOD 128),1)=CHR$(USR(&H7FC1+G+G)):IF (L MOD 128)=&H7F THEN PUT #1,1+(H*2)+(L \ 128)+G*&H100
1370 NEXT L:NEXT H
1380 NEXT G
1390 CLOSE #1:PRINT
1400 O$="DATA"+I$+".ROM":PRINT"Get "O$;
1410 OPEN O$ AS #1 LEN=128:FIELD #1, 128 AS G$
1420 FOR H=&H0 TO &H7F:PRINT".";:FOR L=&H0 TO &HFF
1430 POKE&HD002,&H7F:POKE &HD001,&HC9:V=USR1(H):POKE &HD001,&HC8:V=USR1(L)
1440 MID$(G$,1+(L MOD 128),1)=CHR$(USR(&H7FCB)):IF (L MOD 128)=&H7F THEN PUT #1,1+(H*2)+(L \ 128)
1480 NEXT L:NEXT H
1490 CLOSE #1:PRINT
1500 O$="SRAM"+I$+".SRM":PRINT"Get "O$;
1510 OPEN O$ AS #1 LEN=128:FIELD #1, 128 AS G$
1520 FOR H=&H0 TO &H7:PRINT".";:FOR L=&H0 TO &HFF
1530 POKE&HD002,&H7F:POKE &HD001,&HC9:V=USR1(H+&H80):POKE &HD001,&HC8:V=USR1(L)
1540 MID$(G$,1+(L MOD 128),1)=CHR$(USR(&H7FCB)):IF (L MOD 128)=&H7F THEN PUT #1,1+(H*2)+(L \ 128)
1580 NEXT L:NEXT H
1590 CLOSE #1:PRINT
1970 NEXT S
1980 NEXT P
1990 END
2000 'POKE slotID into 0xD000
2020 'POKE writeAddr into 0xD001/0xD002
2030 'USR1(int value): WRSLT(A=slotID, HL=writeAddr, E=value) -> int writeAddr
2050 RESTORE 3000:A=&HD015
2060 READ X$:IF X$="" THEN GOTO 2100
2070 POKE A,VAL("&h"+X$):A=A+1:GOTO 2060
2100 DEF USR1=&HD015:DEF USR=&HD02D
2990 RETURN
3000               ' ;; machine code
3100 DATA C5      :' 0xD015: PUSH BC         ;; int USR1(int value)
3110 DATA D5      :'         PUSH DE
3120 DATA E5      :'         PUSH HL
3130 DATA F5      :'         PUSH AF
3140 DATA 3A,F8,F7:'         LD A, (0xF7F8)  ;; value
3150 DATA 5F      :'         LD E,A
3160 DATA 3A,00,D0:'         LD A, (0xD000)  ;; slotID
3170 DATA 2A,01,D0:'         LD HL, (0xD001) ;; writeAddr
3180 DATA F3      :'         DI
3190 DATA CD,14,00:'         CALL WRSLT
3200 DATA FB      :'         EI
3210 DATA F1      :'         POP AF
3220 DATA E1      :'         POP HL
3230 DATA D1      :'         POP DE
3240 DATA C1      :'         POP DC
3250 DATA C9      :'         RET
3260 DATA C5      :' 0xD02D: PUSH BC         ;; int USR(int readAddr)
3270 DATA D5      :'         PUSH DE
3280 DATA E5      :'         PUSH HL
3290 DATA F5      :'         PUSH AF
3300 DATA 2A,F8,F7:'         LD HL, (0xF7F8) ;; readAddr
3310 DATA 3A,00,D0:'         LD A, (0xD000)  ;; slotID
3320 DATA F3      :'         DI
3330 DATA CD,0C,00:'         CALL RDSLT
3340 DATA FB      :'         EI
3350 DATA 32,F8,F7:'         LD (0xF7F8), A  ;; <- value (low byte)
3360 DATA AF      :'         XOR A
3370 DATA 32,F9,F7:'         LD (0xF7F9), A  ;; <- 00 (high byte)
3380 DATA F1      :'         POP AF
3390 DATA E1      :'         POP HL
3400 DATA D1      :'         POP DE
3410 DATA C1      :'         POP DC
3420 DATA C9      :'         RET
3990 DATA         :' ;; end of machine code
